# SAMI / Southbrook AI Kitchen Platform — environment secrets template.
# Copy to .env (DO NOT COMMIT .env) and replace placeholders.

# ---- Postgres / Odoo ----
POSTGRES_DB=southbrook
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change-me-strong-password

# Odoo will use POSTGRES_* via docker-compose.
# The DB name Odoo connects to and loads modules into:
ODOO_DB=southbrook

# Odoo master admin password (server-level, NOT the admin user login).
# Used for db management actions (backup, duplicate, list_db when enabled).
ODOO_MASTER_PASSWORD=change-me-master-password

# Host port mapping. Defaults 8169/8172 dodge the canonical 8069/8072 used
# by the OCA-only dev clone at ~/Downloads/Official/V19C/. Set to 8069/8072
# explicitly if you stop V19C and want the canonical Odoo URL.
ODOO_HTTP_PORT=8169
ODOO_LONGPOLLING_PORT=8172

# ---- FreeCAD bridge ----
# Shared secret. Odoo's /plm/cad_callback controller validates incoming
# requests against this; the bridge sends it on every POST to Odoo.
# Generate with: openssl rand -hex 32
FREECAD_BRIDGE_SECRET=change-me-bridge-secret

# Service account the bridge uses for XML-RPC back into Odoo (creating
# ir.attachment records, calling /plm/cad_callback). For local dev this
# can be the admin user; for any deployed environment, create a dedicated
# bridge service user with the smallest privilege set that works.
ODOO_USER=admin
ODOO_API_KEY=admin

# ---- Gemini (Module 6) ----
# Get from https://aistudio.google.com/ — used by southbrook_ai_design only.
# Leave blank until Module 6 starts; the bridge does not need this.
GEMINI_API_KEY=
