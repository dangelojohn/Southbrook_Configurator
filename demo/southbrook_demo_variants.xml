<?xml version="1.0" encoding="utf-8"?>
<!--
  Demo variants — one product.product per cabinet template.

  The 12 cabinet templates use create_variant='dynamic' per Q6,
  so production installs have NO concrete variants until a
  product.config.session commits one. This file pre-materialises
  a representative "default config" variant per template so:

    - Demo orders (southbrook_demo_orders.xml) can reference real
      product variants instead of product.product_product_4
      (which doesn't exist with a no-demo, the NF22 blocker).
    - The Order Builder portal SPA (Track 2) shows correct
      family / width / spec / BoM rollup the moment the demo
      lands, without requiring a configurator session walk.

  Each variant carries default_code (matches Q8 template SKU) +
  list_price (carries the gate-spec retail anchor; Phase-1 polish
  PT-P1-01 layer 3 would later replace these with session-derived
  variants). standard_price (cost) is also seeded to enable the
  Contractor pricelist chain per CLAUDE.md §6 once that becomes
  relevant in Phase 3.

  Pricing anchors (per Signature Series book retail discipline):
    - Base 1-Door 24" Contemporary: $320 retail
    - Base 2-Door 30":              $395
    - Drawer Bank 24" 3-drawer:     $485
    - Wall 1-Door 18":              $285
    - Wall 2-Door 30":              $485
    - Sink Base 30":                $385
    - Tall Pantry 24":              $825
    - Tall Oven 30":                $925
    - Corner 36" Contemporary:      $550
    - Vanity 30" Bath:              $325
    - Accessory (end panel):        $75
    - Worktop (per linear ft):      $150

  noupdate="1" so gate-walk modifications survive subsequent
  -u southbrook_estimating runs.
-->
<odoo noupdate="1">

  <record id="demo_variant_wall_1dr" model="product.product">
    <field name="product_tmpl_id" ref="wall_1dr"/>
    <field name="default_code">SB-WALL-1DR</field>
    <field name="list_price">285.00</field>
    <field name="standard_price">115.00</field>
    <field name="active" eval="True"/>
  </record>

