<?xml version="1.0" encoding="utf-8"?>
<!--
  Signature Spec Sheet — customer-facing PDF, bound to sale.order.

  Per Build Spec section 4 routine #6. The customer's deliverable when they
  hit "Request a Price" — Signature Series styled summary of the configured
  kitchen with cabinet list, totals, and lead time.

  Visual target: docs/southbrook_book_templates.pdf (when #7 lands).
  Current styling: TBD-marked named CSS variables in
  reports/southbrook_report_styles.xml (see NF15).

  Data binding: sale.order. The customer sees their order.

  Phase-1 minimum: header + customer info + line table + total + lead time.
  Phase-2 polish: cover page, Signature Series typographic treatment,
  per-cabinet detail thumbnails.
-->
<odoo>

  <!-- Customer-facing spec sheet -->
  <template id="report_signature_spec_sheet_doc"
            name="Signature Spec Sheet Document">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="o">
        <t t-call="web.external_layout">
          <t t-call="southbrook_estimating.southbrook_report_styles"/>
          <div class="page southbrook-report">
            <div class="sb-illustrative-banner"
                 t-if="env['ir.config_parameter'].sudo().get_param('southbrook.seed_mode') == 'illustrative'">
              ILLUSTRATIVE SEED — demo numbers, not production data.
            </div>

            <h1>Your Southbrook Kitchen</h1>
            <h2>Signature Spec Sheet</h2>
            <hr class="sb-rule"/>

            <div>
              <strong>Customer:</strong>
              <span t-out="o.partner_id.name"/><br/>
              <strong>Reference:</strong>
              <span t-out="o.name"/>
              <span class="sb-muted">
                (v<span t-out="o.version"/>)
              </span><br/>
              <strong>Quote Date:</strong>
              <span t-out="o.date_order"
                    t-options="{'widget': 'date'}"/>
            </div>

            <hr class="sb-rule"/>

            <h2>Cabinets</h2>
            <table>
              <thead>
                <tr>
                  <th>Zone</th>
                  <th>Cabinet</th>
                  <th>Qty</th>
                  <th>Unit Price</th>
                  <th>Line Total</th>
                </tr>
              </thead>
              <tbody>
                <tr t-foreach="o.order_line" t-as="line">
                  <td>
                    <span t-out="dict(line._fields['zone'].selection).get(line.zone, '—')"/>
                    <span t-if="line.zone_label">
                      / <span t-out="line.zone_label"/>
                    </span>
                  </td>
                  <td t-out="line.product_id.display_name or line.name"/>
                  <td t-out="line.product_uom_qty"/>
                  <td t-out="line.price_unit"
                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                  <td t-out="line.price_subtotal"
                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                </tr>
              </tbody>
              <tfoot>
                <tr class="sb-total-row">
                  <td colspan="4">Total</td>
                  <td t-out="o.amount_total"
                      t-options="{'widget': 'monetary', 'display_currency': o.currency_id}"/>
                </tr>
              </tfoot>
            </table>

            <p class="sb-muted">
              This spec sheet was generated by the Southbrook Estimating
              Application. The cabinet specifications and pricing reflect
              your configuration at the time of generation. Real
              manufacturing lead times and any adjustments will be
              confirmed by your assigned dealer.
            </p>
          </div>
        </t>
      </t>
    </t>
  </template>

  <!-- ir.actions.report — binds the template to sale.order -->
  <record id="action_report_signature_spec_sheet" model="ir.actions.report">
    <field name="name">Signature Spec Sheet</field>
    <field name="model">sale.order</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">southbrook_estimating.report_signature_spec_sheet_doc</field>
    <field name="report_file">southbrook_estimating.report_signature_spec_sheet_doc</field>
    <field name="print_report_name">'Spec Sheet - %s' % (object.name)</field>
    <field name="binding_model_id" ref="sale.model_sale_order"/>
    <field name="binding_type">report</field>
  </record>

</odoo>
