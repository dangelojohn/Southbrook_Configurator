<?xml version="1.0" encoding="utf-8"?>
<!--
  res.users Preferences view extension — surface NF7 + NF8 user prefs.
-->
<odoo>

  <record id="view_users_form_southbrook" model="ir.ui.view">
    <field name="name">res.users.form.southbrook</field>
    <field name="model">res.users</field>
    <field name="inherit_id" ref="base.view_users_form"/>
    <field name="arch" type="xml">
      <xpath expr="//page[@name='preferences']" position="inside">
        <group string="Southbrook Order Builder" name="southbrook_prefs">
          <field name="southbrook_default_series"
                 help="NF7 — Amazing Window keyboard-first pattern. Pre-selected on every new order line."/>
          <field name="southbrook_order_entry_mode"
                 help="NF8 — Pro Finish width-first toggle. Flips the inline drawer layout."/>
        </group>
      </xpath>
    </field>
  </record>

</odoo>
