        <field name="x_marathon_sku">9621</field>
        <field name="type">consu</field>
        <field name="is_storable" eval="True"/>
        <field name="x_hardware_category">handle</field>
        <field name="x_hardware_brand_id" ref="brand_marathon"/>
        <field name="x_pricing_pending" eval="True"/>
