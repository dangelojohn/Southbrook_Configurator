<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        36 brands sourced through Marathon Hardware. Original seed
        was 19 (Blum through Generic); +DTC + King Slide added Tier 1
        2026-06-10 from Marathon's hinge/slide category names; +15
        added Tier 2.2 same day from Marathon's homepage /brand/<name>
        feature list (Amerock, Emtek, Schaub, Citterio Giulio, Viefe,
        Roberto Marella, Italiana Ferramenta, Vibo, L&S Lighting,
        FastCap, True Position Tools, Robertson, 3M, Klingspor,
        Eureka).
        Codes are stable identifiers used in xml_ids and the
        hardware_map.json so a brand swap doesn't ripple through code.
    -->
    <record id="brand_blum" model="southbrook.hardware.brand">
        <field name="name">Blum</field>
        <field name="code">blum</field>
        <field name="sequence">10</field>
        <field name="note">Austrian hinge/slide market leader. CLIP top BLUMOTION hinges + MOVENTO/TANDEM slides. Launching at Marathon July 2026.</field>
    </record>
    <record id="brand_salice" model="southbrook.hardware.brand">
        <field name="name">Salice</field>
        <field name="code">salice</field>
        <field name="sequence">20</field>
    </record>
    <record id="brand_dtc" model="southbrook.hardware.brand">
        <field name="name">DTC</field>
        <field name="code">dtc</field>
        <field name="sequence">25</field>
        <field name="note">Chinese hinge/slide maker. Marathon promotes DTC alongside Salice as a top-tier hinge category — homepage navigation calls out "DTC Hinges" as its own bin.</field>
    </record>
    <record id="brand_hettich" model="southbrook.hardware.brand">
        <field name="name">Hettich</field>
        <field name="code">hettich</field>
        <field name="sequence">30</field>
