        <field name="note">Taiwanese drawer-slide OEM. Supplies ball-bearing and undermount slides to multiple distributors, often under their own labeling. Sourced through Marathon for mid-tier slide SKUs.</field>
    </record>
    <record id="brand_richelieu" model="southbrook.hardware.brand">
