<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_southbrook_hardware_brand_list" model="ir.ui.view">
        <field name="name">southbrook.hardware.brand.list</field>
        <field name="model">southbrook.hardware.brand</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="note"/>
            </list>
        </field>
    </record>

    <record id="view_southbrook_hardware_brand_form" model="ir.ui.view">
        <field name="name">southbrook.hardware.brand.form</field>
        <field name="model">southbrook.hardware.brand</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_southbrook_hardware_brand" model="ir.actions.act_window">
        <field name="name">Hardware Brands</field>
        <field name="res_model">southbrook.hardware.brand</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
