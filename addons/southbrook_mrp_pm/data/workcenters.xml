<?xml version="1.0" encoding="utf-8"?>
<!--
  M8 (Manufacturing PM JTBD 2026-06-01) — seed 8 Southbrook work
  centers in mrp.workcenter.

  Pre-fix: mrp.workcenter table empty for SB stations, blocking
  every downstream PM screen + the M3 Send-to-Production target.

  Each station carries:
    name             human label
    code             stable identifier (SB-* prefix matches
                     SB-* cabinet SKU pattern)
    oee_target       85.0 (JTBD recommendation)
    time_efficiency  100.0 (no fudge factor yet)
    costs_hour       $/hr — imported 2026-06-01 from user CSV pack.
                     Rates pulled from import section 1.1 by matching
                     station purpose:
                       SB-SAW       $85  (= CNC rate)
                       SB-EDGE      $65
                       SB-CNC-BORE  $80  (no direct match; between
                                          CNC and PAINT)
                       SB-ASSY      $60  (= ASM)
                       SB-DOOR      $55  (= DOOR Shop rate; door hang
                                          shares labour class)
                       SB-HW        $50
                       SB-QC        $40
                       SB-PACK      $35

  Cycle times per cabinet × station are stored on
  mrp.routing.workcenter records (data/routing_base_1dr.xml), not
  here. This file is the station catalogue; routings reference it.
-->
<odoo>
  <data noupdate="0">

    <record id="workcenter_saw" model="mrp.workcenter">
      <field name="name">Panel Saw / CNC Nesting</field>
      <field name="code">SB-SAW</field>
      <field name="oee_target">85.0</field>
      <field name="time_efficiency">100.0</field>
      <field name="costs_hour">85</field>
    </record>

    <record id="workcenter_edge" model="mrp.workcenter">
      <field name="name">Edge Bander</field>
      <field name="code">SB-EDGE</field>
      <field name="oee_target">85.0</field>
      <field name="time_efficiency">100.0</field>
      <field name="costs_hour">65</field>
    </record>

    <record id="workcenter_cnc_bore" model="mrp.workcenter">
      <field name="name">CNC Boring</field>
      <field name="code">SB-CNC-BORE</field>
      <field name="oee_target">85.0</field>
      <field name="time_efficiency">100.0</field>
      <field name="costs_hour">80</field>
    </record>

    <record id="workcenter_assy" model="mrp.workcenter">
      <field name="name">Carcass Assembly</field>
      <field name="code">SB-ASSY</field>
      <field name="oee_target">85.0</field>
      <field name="time_efficiency">100.0</field>
      <field name="costs_hour">60</field>
    </record>

    <record id="workcenter_door" model="mrp.workcenter">
      <field name="name">Door Hanging</field>
      <field name="code">SB-DOOR</field>
      <field name="oee_target">85.0</field>
      <field name="time_efficiency">100.0</field>
      <field name="costs_hour">55</field>
    </record>

    <record id="workcenter_hw" model="mrp.workcenter">
      <field name="name">Hardware Fitting</field>
      <field name="code">SB-HW</field>
      <field name="oee_target">85.0</field>
      <field name="time_efficiency">100.0</field>
      <field name="costs_hour">50</field>
    </record>

    <record id="workcenter_qc" model="mrp.workcenter">
      <field name="name">Quality Control</field>
      <field name="code">SB-QC</field>
      <field name="oee_target">85.0</field>
      <field name="time_efficiency">100.0</field>
      <field name="costs_hour">40</field>
    </record>

    <record id="workcenter_pack" model="mrp.workcenter">
      <field name="name">Pack &amp; Label</field>
      <field name="code">SB-PACK</field>
      <field name="oee_target">85.0</field>
      <field name="time_efficiency">100.0</field>
      <field name="costs_hour">35</field>
    </record>

  </data>
</odoo>
