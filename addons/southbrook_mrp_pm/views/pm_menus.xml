<?xml version="1.0" encoding="utf-8"?>
<!--
  M1 v0 + M4 — Southbrook PM menu structure.

  The full PM dashboard from the JTBD analysis (one screen with
  tiles for Queue + Floor Load + Equipment Alerts + Late count)
  is M10 polish — needs a custom OWL component + computed
  aggregations. This v0 ships the SAME information surface as 5
  filtered Odoo actions under a single 'Southbrook PM' root menu,
  so the PM can:

     Ready Queue       → confirmed MOs (M4)
     In Production     → MOs currently running (state=progress)
     Late Orders       → not done AND deadline < now
     Floor Load        → all work centers, kanban for at-a-glance
     Equipment         → maintenance.equipment list

  Each item leverages standard Odoo views (no custom JS), so it's
  immediately useful and survives Odoo upgrades. The richer KPI
  cards land in a follow-up commit once the data-collection
  hooks (start/stop scans, OEE inputs) are in place.
-->
<odoo>
  <data>

    <!-- ============================================================
         Root menu — Southbrook PM. Sits next to Manufacturing in
         the top nav; sequence 70 keeps it after Sales but before
         Settings.
         ============================================================ -->
    <menuitem
        id="menu_southbrook_pm_root"
        name="Southbrook PM"
        sequence="70"
        web_icon="mrp,static/description/icon.png"/>

    <!-- ============================================================
         M4 — Ready for Production queue
         ============================================================ -->
    <record id="action_pm_ready_queue" model="ir.actions.act_window">
      <field name="name">Ready for Production</field>
      <field name="res_model">mrp.production</field>
      <field name="view_mode">list,form,kanban</field>
      <field name="domain">[('state','in',['confirmed','progress'])]</field>
      <field name="context">{'search_default_group_by_state':1}</field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          No manufacturing orders are ready for production.
        </p>
        <p>
          Orders land here once the sales rep confirms a quote
          and clicks Send to Production. The Floor Manager
          picks the topmost order by deadline.
        </p>
      </field>
    </record>
    <menuitem
        id="menu_pm_ready_queue"
        parent="menu_southbrook_pm_root"
        name="Ready Queue"
        action="action_pm_ready_queue"
        sequence="10"/>

    <!-- ============================================================
         In Production — MOs currently running
         ============================================================ -->
    <record id="action_pm_in_production" model="ir.actions.act_window">
      <field name="name">In Production</field>
      <field name="res_model">mrp.production</field>
      <field name="view_mode">list,form,kanban</field>
      <field name="domain">[('state','=','progress')]</field>
    </record>
    <menuitem
        id="menu_pm_in_production"
        parent="menu_southbrook_pm_root"
        name="In Production"
        action="action_pm_in_production"
        sequence="20"/>

    <!-- ============================================================
         Late Orders — past deadline, not done
         ============================================================ -->
    <record id="action_pm_late" model="ir.actions.act_window">
      <field name="name">Late Orders</field>
      <field name="res_model">mrp.production</field>
      <field name="view_mode">list,form</field>
      <!--
        date_deadline < now AND state not in (done, cancel). Using
        context_today() for portable 'now'. Odoo expands the domain
        at query time.
      -->
      <field name="domain">
        [
          ('state','not in',['done','cancel']),
          ('date_deadline','&lt;',time.strftime('%Y-%m-%d %H:%M:%S'))
        ]
      </field>
      <field name="help" type="html">
        <p class="o_view_nocontent_smiling_face">
          No late orders. Good shop day.
        </p>
      </field>
    </record>
    <menuitem
        id="menu_pm_late"
        parent="menu_southbrook_pm_root"
        name="Late Orders"
        action="action_pm_late"
        sequence="30"/>

    <!-- ============================================================
         Floor Load — work-center kanban
         ============================================================ -->
    <record id="action_pm_floor_load" model="ir.actions.act_window">
      <field name="name">Floor Load</field>
      <field name="res_model">mrp.workcenter</field>
      <field name="view_mode">kanban,list,form</field>
      <field name="context">{'search_default_group_by_active':1}</field>
    </record>
    <menuitem
        id="menu_pm_floor_load"
        parent="menu_southbrook_pm_root"
        name="Floor Load"
        action="action_pm_floor_load"
        sequence="40"/>

    <!-- ============================================================
         Equipment — maintenance list
         ============================================================ -->
    <record id="action_pm_equipment" model="ir.actions.act_window">
      <field name="name">Equipment</field>
      <field name="res_model">maintenance.equipment</field>
      <field name="view_mode">list,kanban,form</field>
    </record>
    <menuitem
        id="menu_pm_equipment"
        parent="menu_southbrook_pm_root"
        name="Equipment"
        action="action_pm_equipment"
        sequence="50"/>

  </data>
</odoo>
