<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sb_placement_rule_list" model="ir.ui.view">
        <field name="name">sb.placement.rule.list</field>
        <field name="model">sb.placement.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="kind"/>
                <field name="theme"/>
                <field name="appliance_kind"/>
                <field name="priority"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_sb_placement_rule_form" model="ir.ui.view">
        <field name="name">sb.placement.rule.form</field>
        <field name="model">sb.placement.rule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="kind"/>
                            <field name="theme"/>
                            <field name="appliance_kind"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <field name="constraint_json"/>
                    <field name="note"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sb_placement_rule" model="ir.actions.act_window">
        <field name="name">Placement Rules</field>
        <field name="res_model">sb.placement.rule</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
