<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Record rule: a portal user may only see/edit kitchen projects
        whose partner_id matches their res.users.partner_id (i.e. their
        OWN projects). Internal users (sales/manager) keep the existing
        Module-5 ACL.
    -->
    <record id="rule_portal_kitchen_project_own_only" model="ir.rule">
        <field name="name">Portal: own kitchen projects only</field>
        <field name="model_id" ref="southbrook_kitchen_workspace.model_sb_kitchen_project"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('partner_id', '=', user.partner_id.id)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>

    <!-- Same shape on design.option (so a portal user can list options for
         their own project only). -->
    <record id="rule_portal_design_option_own_only" model="ir.rule">
        <field name="name">Portal: own design options only</field>
        <field name="model_id" ref="southbrook_kitchen_workspace.model_sb_kitchen_design_option"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('project_id.partner_id', '=', user.partner_id.id)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">0</field>
        <field name="perm_unlink">0</field>
    </record>
</odoo>
