<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="product_config_category" model="ir.module.category">
        <field name="name">Product Configurator</field>
    </record>

    <record id="group_product_configurator" model="res.groups">
        <field name="name">User</field>
        <field name="implied_ids" eval="[(4, ref('product.group_product_variant'))]" />
    </record>

    <record id="group_product_configurator_manager" model="res.groups">
        <field name="name">Manager</field>
        <field
            name="implied_ids"
            eval="[(4, ref('product_configurator.group_product_configurator'))]"
        />
        <field name="user_ids" eval="[(4, ref('base.user_admin'))]" />
    </record>

    <!-- Set default to all employees -->
    <record model="res.groups" id="base.group_user">
        <field
            name="implied_ids"
            eval="[(4, ref('product_configurator.group_product_configurator'))]"
        />
    </record>
    <record model="res.users" id="base.user_root">
        <field
            eval="[(4, ref('product_configurator.group_product_configurator_manager'))]"
            name="group_ids"
        />
    </record>

    <!--
        [REF] (f) — Portal scoping for saved configurations.

        Portal users (logged-in customers) already have read ACL on
        product.config.session via ir.model.access.csv. Without a row-
        level rule, that ACL would let portal user A read portal user
        B's sessions — a privacy leak the moment we expose
        /my/configurations.

        This rule restricts portal-group reads to sessions whose
        user_id is the current user. Internal users (group_user, which
        implies group_product_configurator) are unaffected — they
        already have broader CRUD via their own ACL row.

        Public/anonymous buyers are NOT covered by this rule: they
        belong to base.group_public, not base.group_portal. Their
        sessions are scoped by the existing public-buyer flow in
        website_product_configurator's controller (sudo'd reads on a
        single session_id from the HTTP session cookie).
    -->
    <record id="product_config_session_portal_rule" model="ir.rule">
        <field name="name">Config Session: portal users see only their own</field>
        <field name="model_id" ref="model_product_config_session" />
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="False" />
        <field name="perm_create" eval="False" />
        <field name="perm_unlink" eval="False" />
    </record>

    <!--
        FEATURE 2 — Saved-configs bookmark ownership rules.

        Portal users:
          - read   their own bookmarks
          - write  their own bookmarks (rename, archive)
          - create their own bookmarks (only with user_id = self)
          - unlink their own bookmarks (archive preferred; hard-
            delete supported for buyer-initiated remove)

        Public users (anonymous buyers) get NO access to bookmarks —
        they're a logged-in-buyer feature. Anonymous sessions can
        still be saved/resumed via the storefront cookie mechanism;
        that path doesn't touch product.config.bookmark.

        Internal users (base.group_user) get full access via their
        CSV ACL row — no rule restriction. This lets advisors /
        operators view and manage customer bookmarks from the back-
        office.
    -->
    <record id="product_config_bookmark_portal_rule" model="ir.rule">
        <field name="name">Config Bookmark: portal users own theirs</field>
        <field name="model_id" ref="model_product_config_bookmark" />
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_portal'))]" />
        <field name="perm_read" eval="True" />
        <field name="perm_write" eval="True" />
        <field name="perm_create" eval="True" />
        <field name="perm_unlink" eval="True" />
    </record>
</odoo>
