<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            G2a opt-in gate. Defaults to FALSE so installing this addon
            does NOT change MO confirm behaviour. Flip to True in
            Settings → Technical → System Parameters to activate the
            on-confirm bridge POST + the Regenerate CAD button.

            Uses set_param so the call is idempotent — re-runs are safe.
            The URL and secret parameters are intentionally NOT seeded
            here; the code falls back to DEFAULT_BRIDGE_URL and admin
            sets the secret via the UI on first use.
        -->
        <function model="ir.config_parameter" name="set_param">
            <value>freecad_bridge.enabled</value>
            <value>false</value>
        </function>
    </data>
</odoo>
