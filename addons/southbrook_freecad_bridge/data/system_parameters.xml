<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            G2a opt-in gate. Defaults to FALSE so installing this addon
            does NOT change MO confirm behaviour. Flip to True in
            Settings → Technical → System Parameters to activate the
            on-confirm bridge POST + the Regenerate CAD button.

            set_param is idempotent: re-running -u does NOT overwrite an
            admin's True value (set_param does overwrite, but noupdate=1
            means this call only fires on -i, not -u). For new installs
            the gate lands explicitly OFF.
        -->
        <function model="ir.config_parameter" name="set_param"
                  eval="('freecad_bridge.enabled', 'false')"/>
    </data>
</odoo>
