<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Adds the CAD Artifacts tab, the colour-coded shop-floor kanban
        badge for x_cad_status, and the "Regenerate CAD" manager button.
        Behaviour is gated by the `freecad_bridge.enabled` system parameter
        (G2a). The button raises UserError when the gate is off; the
        on-confirm hook silently no-ops.
    -->
    <record id="view_mrp_production_form_cad" model="ir.ui.view">
        <field name="name">mrp.production.form.cad</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="CAD Artifacts" name="cad_artifacts">
                    <group>
                        <field name="x_cad_status" widget="badge"
                               decoration-info="x_cad_status == 'pending'"
                               decoration-warning="x_cad_status == 'rendering'"
                               decoration-success="x_cad_status == 'done'"
                               decoration-danger="x_cad_status == 'error'"/>
                        <field name="x_plm_eco_id"/>
                    </group>
                    <button name="action_regenerate_cad"
                            string="Regenerate CAD"
                            type="object" class="btn-secondary"
                            groups="mrp.group_mrp_manager"
                            confirm="Post a fresh render job to the FreeCAD bridge for this MO? Existing artifacts will be superseded."/>
                    <field name="x_cad_attachment_ids" widget="many2many_binary"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
