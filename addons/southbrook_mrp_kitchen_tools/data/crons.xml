<?xml version="1.0" encoding="utf-8"?>
<!--
  Daily cron — sweeps tool assets to flag any whose sharpening or
  calibration interval has elapsed. The cron itself only updates the
  asset's next_*_due_date when blank from product defaults; the
  readiness check in commit 4 reads next_*_due_date against today and
  blocks the workorder on overdue assets.
-->
<odoo>
    <data noupdate="1">

        <record id="cron_tool_asset_maintenance_sweep"
                model="ir.cron">
            <field name="name">Southbrook: Tool Asset Maintenance Sweep</field>
            <field name="model_id" ref="model_southbrook_tool_asset"/>
            <field name="state">code</field>
            <field name="code">model._cron_maintenance_sweep()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
            <field name="user_id" ref="base.user_root"/>
        </record>

    </data>
</odoo>
