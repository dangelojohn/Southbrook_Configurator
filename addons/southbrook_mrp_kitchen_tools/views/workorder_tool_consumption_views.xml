<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_workorder_tool_consumption_list" model="ir.ui.view">
        <field name="name">southbrook.workorder.tool.consumption.list</field>
        <field name="model">southbrook.workorder.tool.consumption</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="workorder_id"/>
                <field name="production_id"/>
                <field name="workcenter_id"/>
                <field name="asset_id" optional="show"/>
                <field name="product_id" optional="show"/>
                <field name="employee_id" optional="hide"/>
                <field name="quantity" sum="Total Qty"/>
                <field name="unit_cost" optional="hide"/>
                <field name="total_cost" sum="Total Cost"/>
                <field name="create_date" widget="datetime" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_workorder_tool_consumption_form" model="ir.ui.view">
        <field name="name">southbrook.workorder.tool.consumption.form</field>
        <field name="model">southbrook.workorder.tool.consumption</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Work Order">
                            <field name="workorder_id"/>
                            <field name="production_id" readonly="1"/>
                            <field name="workcenter_id" readonly="1"/>
                            <field name="employee_id"/>
                        </group>
                        <group string="Item Consumed">
                            <field name="asset_id"/>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="unit_cost"/>
                            <field name="total_cost" readonly="1"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_workorder_tool_consumption_search" model="ir.ui.view">
        <field name="name">southbrook.workorder.tool.consumption.search</field>
        <field name="model">southbrook.workorder.tool.consumption</field>
        <field name="arch" type="xml">
            <search>
                <field name="workorder_id"/>
                <field name="production_id"/>
                <field name="workcenter_id"/>
                <field name="asset_id"/>
                <field name="product_id"/>
                <field name="employee_id"/>
                <group>
                    <filter name="group_workorder" string="Work Order"
                            context="{'group_by': 'workorder_id'}"/>
                    <filter name="group_production" string="Manufacturing Order"
                            context="{'group_by': 'production_id'}"/>
                    <filter name="group_workcenter" string="Work Center"
                            context="{'group_by': 'workcenter_id'}"/>
                    <filter name="group_asset" string="Tool Asset"
                            context="{'group_by': 'asset_id'}"/>
                    <filter name="group_product" string="Product"
                            context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_workorder_tool_consumption" model="ir.actions.act_window">
        <field name="name">Work Order Tool Consumption</field>
        <field name="res_model">southbrook.workorder.tool.consumption</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_workorder_tool_consumption_search"/>
    </record>

</odoo>
