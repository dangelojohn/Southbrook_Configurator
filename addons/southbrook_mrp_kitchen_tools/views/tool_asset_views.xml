<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ─── List ────────────────────────────────────────────────────── -->
    <record id="view_tool_asset_list" model="ir.ui.view">
        <field name="name">southbrook.tool.asset.list</field>
        <field name="model">southbrook.tool.asset</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active"
                  decoration-success="lifecycle_state == 'available'"
                  decoration-info="lifecycle_state in ('in_use', 'checked_out', 'new')"
                  decoration-warning="lifecycle_state in ('needs_cleaning', 'needs_sharpening', 'needs_calibration')"
                  decoration-danger="lifecycle_state in ('broken', 'under_maintenance')">
                <field name="code"/>
                <field name="name"/>
                <field name="product_id"/>
                <field name="tool_family" widget="badge"/>
                <field name="tool_crib_id"/>
                <field name="workcenter_id"/>
                <field name="assigned_employee_id"/>
                <field name="lifecycle_state" widget="badge"/>
                <field name="condition" widget="badge"
                       decoration-success="condition == 'excellent'"
                       decoration-warning="condition in ('worn', 'dull')"
                       decoration-danger="condition in ('damaged', 'unsafe')"/>
                <field name="remaining_life_qty" optional="show"/>
                <field name="next_sharpening_due_date" optional="show"/>
                <field name="next_calibration_due_date" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ─── Kanban ──────────────────────────────────────────────────── -->
    <record id="view_tool_asset_kanban" model="ir.ui.view">
        <field name="name">southbrook.tool.asset.kanban</field>
        <field name="model">southbrook.tool.asset</field>
        <field name="arch" type="xml">
            <kanban default_group_by="lifecycle_state" class="o_kanban_small_column">
                <field name="lifecycle_state"/>
                <field name="condition"/>
                <field name="tool_family"/>
                <field name="remaining_life_qty"/>
                <field name="life_unit"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_record_top">
                            <strong class="o_kanban_record_title">
                                <field name="code"/>
                                <span> </span>
                                <field name="name"/>
                            </strong>
                        </div>
                        <div class="o_kanban_record_body">
                            <div class="text-muted">
                                <i class="fa fa-tag" title="Family"/>
                                <field name="tool_family"/>
                            </div>
                            <div>
                                <i class="fa fa-archive" title="Crib"/>
                                <field name="tool_crib_id"/>
                            </div>
                            <div t-if="record.remaining_life_qty.raw_value">
                                <i class="fa fa-tachometer" title="Remaining life"/>
                                <field name="remaining_life_qty"/>
                                <field name="life_unit"/>
                            </div>
                        </div>
                        <div class="o_kanban_record_bottom">
                            <div class="oe_kanban_bottom_left">
                                <field name="condition" widget="label_selection"
                                       options="{'classes': {'excellent': 'success', 'good': 'info', 'worn': 'warning', 'dull': 'warning', 'damaged': 'danger', 'unsafe': 'danger'}}"/>
                            </div>
                            <div class="oe_kanban_bottom_right">
                                <field name="assigned_employee_id" widget="many2one_avatar_user"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ─── Search ──────────────────────────────────────────────────── -->
    <record id="view_tool_asset_search" model="ir.ui.view">
        <field name="name">southbrook.tool.asset.search</field>
        <field name="model">southbrook.tool.asset</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <field name="product_id"/>
                <field name="serial_number"/>
                <field name="tool_family"/>
                <field name="workcenter_id"/>
                <field name="tool_crib_id"/>
                <field name="assigned_employee_id"/>
                <filter name="available" string="Available"
                        domain="[('is_available', '=', True)]"/>
                <filter name="in_use" string="In Use"
                        domain="[('lifecycle_state', '=', 'in_use')]"/>
                <filter name="checked_out" string="Checked Out"
                        domain="[('lifecycle_state', '=', 'checked_out')]"/>
                <separator/>
                <filter name="needs_sharpening" string="Needs Sharpening"
                        domain="[('lifecycle_state', '=', 'needs_sharpening')]"/>
                <filter name="needs_calibration" string="Needs Calibration"
                        domain="[('lifecycle_state', '=', 'needs_calibration')]"/>
                <filter name="needs_cleaning" string="Needs Cleaning"
                        domain="[('lifecycle_state', '=', 'needs_cleaning')]"/>
                <filter name="under_maintenance" string="Under Maintenance"
                        domain="[('lifecycle_state', '=', 'under_maintenance')]"/>
                <filter name="broken" string="Broken"
                        domain="[('lifecycle_state', '=', 'broken')]"/>
                <separator/>
                <filter name="dull_or_damaged" string="Dull / Damaged"
                        domain="[('condition', 'in', ('dull', 'damaged', 'unsafe'))]"/>
                <group>
                    <filter name="group_lifecycle" string="Lifecycle State"
                            context="{'group_by': 'lifecycle_state'}"/>
                    <filter name="group_family" string="Tool Family"
                            context="{'group_by': 'tool_family'}"/>
                    <filter name="group_crib" string="Tool Crib"
                            context="{'group_by': 'tool_crib_id'}"/>
                    <filter name="group_workcenter" string="Work Center"
                            context="{'group_by': 'workcenter_id'}"/>
                    <filter name="group_condition" string="Condition"
                            context="{'group_by': 'condition'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ─── Form ────────────────────────────────────────────────────── -->
    <record id="view_tool_asset_form" model="ir.ui.view">
        <field name="name">southbrook.tool.asset.form</field>
        <field name="model">southbrook.tool.asset</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_in_use" string="In Use"
                            type="object" class="btn-secondary"
                            invisible="lifecycle_state != 'available'"
                            groups="southbrook_mrp_kitchen_tools.group_tool_operator"/>
                    <button name="action_mark_available" string="Available"
                            type="object" class="oe_highlight"
                            invisible="lifecycle_state in ('available', 'retired', 'scrapped', 'broken')"
                            groups="southbrook_mrp_kitchen_tools.group_tool_operator"/>
                    <button name="action_mark_needs_sharpening"
                            string="Send to Sharpening"
                            type="object" class="btn-warning"
                            invisible="lifecycle_state in ('needs_sharpening', 'under_maintenance', 'broken', 'retired', 'scrapped')"
                            groups="southbrook_mrp_kitchen_tools.group_tool_operator"/>
                    <button name="action_mark_needs_calibration"
                            string="Send to Calibration"
                            type="object" class="btn-warning"
                            invisible="lifecycle_state in ('needs_calibration', 'under_maintenance', 'broken', 'retired', 'scrapped')"
                            groups="southbrook_mrp_kitchen_tools.group_tool_operator"/>
                    <button name="action_mark_broken" string="Mark Broken"
                            type="object" class="btn-danger"
                            invisible="lifecycle_state in ('broken', 'retired', 'scrapped')"
                            groups="southbrook_mrp_kitchen_tools.group_tool_crib_manager"
                            confirm="Mark this asset as broken? Operators will lose access until it's repaired."/>
                    <button name="action_retire" string="Retire"
                            type="object"
                            invisible="lifecycle_state in ('retired', 'scrapped')"
                            groups="southbrook_mrp_kitchen_tools.group_tool_crib_manager"
                            confirm="Retire this asset?"/>
                    <field name="lifecycle_state" widget="statusbar"
                           statusbar_visible="new,available,in_use,checked_out"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="code" readonly="1"/>
                            <span> </span>
                            <field name="name" placeholder="Asset name..."/>
                        </h1>
                    </div>
                    <group>
                        <group string="Identity">
                            <field name="product_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="tool_category_id" readonly="1"/>
                            <field name="tool_family" readonly="1"/>
                            <field name="serial_number"/>
                            <field name="barcode"/>
                        </group>
                        <group string="Status">
                            <field name="condition"/>
                            <field name="is_available" readonly="1"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <group string="Location / Assignment">
                            <field name="tool_crib_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="workcenter_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="location_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="equipment_id"
                                   options="{'no_create_edit': True}"/>
                        </group>
                        <group string="Holder">
                            <field name="assigned_employee_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="current_holder_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Life Tracking" name="life">
                            <group>
                                <group>
                                    <field name="remaining_life_qty"/>
                                    <field name="estimated_life_qty"/>
                                    <field name="life_unit"/>
                                    <field name="total_usage_qty"/>
                                </group>
                                <group>
                                    <field name="last_used_date"/>
                                    <field name="last_used_workorder_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="Maintenance" name="maintenance">
                            <group>
                                <group string="Sharpening / Calibration">
                                    <field name="last_sharpened_date"/>
                                    <field name="next_sharpening_due_date"/>
                                    <field name="last_calibrated_date"/>
                                    <field name="next_calibration_due_date"/>
                                </group>
                                <group string="Inspection / Cleaning">
                                    <field name="last_inspected_date"/>
                                    <field name="next_inspection_due_date"/>
                                    <field name="last_cleaned_date"/>
                                </group>
                            </group>
                        </page>
                        <page string="Purchase / Warranty" name="purchase">
                            <group>
                                <group>
                                    <field name="vendor_id"
                                           options="{'no_create_edit': True}"/>
                                    <field name="purchase_date"/>
                                    <field name="purchase_cost"/>
                                </group>
                                <group>
                                    <field name="warranty_expiration_date"/>
                                </group>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <group>
                                <field name="notes"/>
                                <field name="safety_notes"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_tool_asset" model="ir.actions.act_window">
        <field name="name">Tool Assets</field>
        <field name="res_model">southbrook.tool.asset</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_tool_asset_search"/>
    </record>

</odoo>
