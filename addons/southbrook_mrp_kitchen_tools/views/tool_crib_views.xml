<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tool_crib_list" model="ir.ui.view">
        <field name="name">southbrook.tool.crib.list</field>
        <field name="model">southbrook.tool.crib</field>
        <field name="arch" type="xml">
            <list decoration-muted="not active">
                <field name="code"/>
                <field name="name"/>
                <field name="responsible_id"/>
                <field name="stock_location_id" optional="show"/>
                <field name="asset_count"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_tool_crib_form" model="ir.ui.view">
        <field name="name">southbrook.tool.crib.form</field>
        <field name="model">southbrook.tool.crib</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_assets" type="object"
                                class="oe_stat_button" icon="fa-wrench">
                            <field name="asset_count" widget="statinfo"
                                   string="Assets"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived"
                            bg_color="text-bg-danger"
                            invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Tool crib name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="responsible_id"/>
                            <field name="stock_location_id"
                                   options="{'no_create_edit': True}"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="workcenter_ids" widget="many2many_tags"
                                   options="{'no_create_edit': True}"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_tool_crib" model="ir.actions.act_window">
        <field name="name">Tool Cribs</field>
        <field name="res_model">southbrook.tool.crib</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
