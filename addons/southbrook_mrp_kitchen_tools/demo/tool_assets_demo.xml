<?xml version="1.0" encoding="utf-8"?>
<!--
  ~20 demo tool assets covering the realistic Southbrook shop floor:

    * 3 saw blades (1 in use, 1 dull/needs sharpening, 1 available)
    * 4 CNC bits (compression / downcut / upcut / vgroove)
    * 3 boring bits (35mm hinge / 5mm shelf pin / confirmat)
    * 2 spray guns (1 available + 1 needs cleaning)
    * 2 measuring tools (digital caliper, moisture meter) with
      calibration dates
    * 1 torque driver
    * 4 jigs (hinge / handle / drawer / door squaring)

  The demo scenarios in commit 6 reference these xmlids so e.g.
  "CNC blocked because 3mm downcut bit is under maintenance" can
  set asset_cnc_bit_downcut_3.lifecycle_state.
-->
<odoo>
    <data noupdate="1">

        <!-- ─── Tool products (created first; tool assets reference them) ── -->

        <record id="tool_prod_blade_mel_305_96t" model="product.product">
            <field name="name">305mm 96T Melamine Panel Saw Blade</field>
            <field name="default_code">SBK-TOOL-BLADE-MEL-305-96T</field>
            <field name="type">consu</field>
            <field name="is_storable">True</field>
            <field name="x_southbrook_is_tool">True</field>
            <field name="x_southbrook_is_reusable_tool">True</field>
            <field name="x_southbrook_tool_category_id"
                   ref="cat_blade_melamine"/>
            <field name="x_southbrook_tool_family">saw_blade</field>
            <field name="x_southbrook_directness">direct_production_tool</field>
            <field name="x_southbrook_blade_diameter_mm">305</field>
            <field name="x_southbrook_tooth_count">96</field>
            <field name="x_southbrook_bore_size_mm">30</field>
            <field name="x_southbrook_estimated_life_qty">800</field>
            <field name="x_southbrook_estimated_life_unit">cuts</field>
            <field name="x_southbrook_sharpening_interval_qty">700</field>
