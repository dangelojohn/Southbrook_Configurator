<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_production_form_mi" model="ir.ui.view">
        <field name="name">mrp.production.form.manufacturing.intelligence</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="manufacturing_intelligence" string="Intelligence">
                    <button name="action_recompute_manufacturing_intelligence"
                            string="Recompute Intelligence"
                            type="object"
                            class="btn-primary"/>
                    <group>
                        <group>
                            <field name="x_mi_status"
                                   widget="badge"
                                   decoration-success="x_mi_status == 'ok'"
                                   decoration-warning="x_mi_status == 'review'"
                                   decoration-danger="x_mi_status == 'blocked'"/>
                            <field name="x_mi_next_action"/>
                            <field name="x_mi_bottleneck_workcenter_id"/>
                        </group>
                        <group>
                            <field name="x_mi_blocker_count"/>
                            <field name="x_mi_warning_count"/>
                            <field name="x_mi_yield_pct"/>
                            <field name="x_mi_waste_area_m2"/>
                        </group>
                    </group>
                    <field name="x_mi_check_ids" readonly="1">
                        <list>
                            <field name="severity"/>
                            <field name="category"/>
                            <field name="name"/>
                            <field name="message"/>
                            <field name="recommendation"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
