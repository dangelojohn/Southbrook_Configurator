<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbk_operation_template_list" model="ir.ui.view">
        <field name="name">southbrook.kitchen.operation.template.list</field>
        <field name="model">southbrook.kitchen.operation.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="code"/>
                <field name="name"/>
                <field name="operation_category"/>
                <field name="default_workcenter_id"/>
                <field name="quantity_driver_type"/>
                <field name="minutes_per_unit"/>
                <field name="default_setup_time_min"/>
                <field name="default_changeover_time_min"/>
                <field name="requires_qc"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sbk_operation_template_form" model="ir.ui.view">
        <field name="name">southbrook.kitchen.operation.template.form</field>
        <field name="model">southbrook.kitchen.operation.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Operation name"/></h1>
                        <h3><field name="code" placeholder="OP_CODE"/></h3>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="operation_category"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group string="Routing">
                            <field name="default_workcenter_id"/>
                            <field name="alternative_workcenter_ids" widget="many2many_tags"/>
                            <field name="blocks_next_operation"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Duration Formula" name="duration">
                            <group>
                                <group string="Time Inputs">
                                    <field name="default_setup_time_min"/>
                                    <field name="default_changeover_time_min"/>
                                    <field name="quantity_driver_type"/>
                                    <field name="minutes_per_unit"/>
                                </group>
                                <group string="Multipliers">
                                    <field name="material_adjustment_factor"/>
                                    <field name="finish_adjustment_factor"/>
                                    <field name="complexity_factor"/>
                                </group>
                            </group>
                            <p class="text-muted">
                                Formula: <code>setup + changeover + driver_value × min/unit × material × finish × complexity</code>.
                                Result rounded up to the nearest minute, floored at 0.
                            </p>
                        </page>
                        <page string="Capability Gating" name="capability">
                            <group>
                                <field name="supported_material_ids" widget="many2many_tags"/>
                                <field name="supported_finish_ids" widget="many2many_tags"/>
                                <field name="required_skill_ids" widget="many2many_tags"/>
                            </group>
                        </page>
                        <page string="Shop-Floor + QC" name="shop_floor">
                            <group>
                                <group>
                                    <field name="requires_qc"/>
                                    <field name="creates_rework_allowed"/>
                                </group>
                            </group>
                            <group string="Required Documents">
                                <field name="required_documents" nolabel="1"/>
                            </group>
                            <group string="Shop-Floor Instruction">
                                <field name="shop_floor_instruction" nolabel="1"/>
                            </group>
                            <group string="QC Checklist">
                                <field name="qc_checklist" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_sbk_operation_template_search" model="ir.ui.view">
        <field name="name">southbrook.kitchen.operation.template.search</field>
        <field name="model">southbrook.kitchen.operation.template</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="default_workcenter_id"/>
                <filter name="filter_requires_qc" string="Requires QC"
                        domain="[('requires_qc', '=', True)]"/>
                <filter name="filter_creates_rework_allowed" string="Rework Allowed"
                        domain="[('creates_rework_allowed', '=', True)]"/>
                <separator/>
                <filter name="groupby_category" string="Category"
                        context="{'group_by': 'operation_category'}"/>
                <filter name="groupby_workcenter" string="Default Work Center"
                        context="{'group_by': 'default_workcenter_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_sbk_operation_template" model="ir.actions.act_window">
        <field name="name">Kitchen Operation Templates</field>
        <field name="res_model">southbrook.kitchen.operation.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
