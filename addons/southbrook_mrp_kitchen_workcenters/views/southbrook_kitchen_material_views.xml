<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sbk_material_list" model="ir.ui.view">
        <field name="name">southbrook.kitchen.material.list</field>
        <field name="model">southbrook.kitchen.material</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="requires_finishing"/>
                <field name="can_be_edge_banded"/>
                <field name="is_subcontract_default"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_sbk_material_form" model="ir.ui.view">
        <field name="name">southbrook.kitchen.material.form</field>
        <field name="model">southbrook.kitchen.material</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="requires_finishing"/>
                            <field name="can_be_edge_banded"/>
                            <field name="is_subcontract_default"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="note" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sbk_material" model="ir.actions.act_window">
        <field name="name">Kitchen Materials</field>
        <field name="res_model">southbrook.kitchen.material</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
