<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        mrp.workorder form — surfaces the kitchen-formula expected,
        variance, costing, rework, and downtime fields plus the
        Recalc button.
    -->

    <record id="view_mrp_workorder_form_sbk_kitchen" model="ir.ui.view">
        <field name="name">mrp.production.workorder.form.sbk.kitchen</field>
        <field name="model">mrp.workorder</field>
        <field name="inherit_id" ref="mrp.mrp_production_workorder_form_view_inherit"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="Southbrook Kitchen Metrics">
                    <group>
                        <field name="x_sbk_kitchen_expected_min"/>
                        <field name="x_sbk_variance_min" readonly="1"/>
                        <field name="x_sbk_estimated_cost" readonly="1"/>
                        <field name="x_sbk_actual_cost" readonly="1"/>
                        <field name="x_sbk_cost_variance" readonly="1"/>
                    </group>
                    <group>
                        <field name="x_sbk_rework_count" readonly="1"/>
                        <field name="x_sbk_rework_cost" readonly="1"/>
                        <field name="x_sbk_downtime_min" readonly="1"/>
                        <field name="x_sbk_downtime_cost" readonly="1"/>
                        <button name="action_sbk_recalc_kitchen_duration"
                                type="object"
                                string="Recalc Kitchen Duration"
                                class="oe_highlight"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
