<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>
    <record id="view_southbrook_data_quality_issue_list" model="ir.ui.view">
      <field name="name">southbrook.project.data.quality.issue.list</field>
      <field name="model">southbrook.project.data.quality.issue</field>
      <field name="arch" type="xml">
        <list string="Data Quality Issues"
              decoration-danger="severity == 'blocker'"
              decoration-warning="severity == 'warning'"
              decoration-muted="state in ('excluded', 'archived')">
          <field name="issue_type"/>
          <field name="severity" widget="badge"/>
          <field name="name"/>
          <field name="model_name"/>
          <field name="res_id"/>
          <field name="state" widget="badge"/>
          <field name="dry_run"/>
          <field name="recommended_action"/>
        </list>
      </field>
    </record>

    <record id="view_southbrook_data_quality_issue_form" model="ir.ui.view">
      <field name="name">southbrook.project.data.quality.issue.form</field>
      <field name="model">southbrook.project.data.quality.issue</field>
      <field name="arch" type="xml">
        <form string="Data Quality Issue">
          <header>
            <button name="action_exclude_from_pm_reporting"
                    string="Exclude from PM Reporting"
                    type="object"
                    class="btn-secondary"
                    invisible="state != 'new'"/>
            <button name="action_archive_issue"
                    string="Archive Issue"
                    type="object"
                    class="btn-secondary"
                    invisible="state == 'archived'"/>
            <field name="state" widget="statusbar"/>
          </header>
          <sheet>
            <group>
              <group>
                <field name="issue_type"/>
                <field name="severity"/>
                <field name="dry_run"/>
              </group>
              <group>
                <field name="model_name"/>
                <field name="res_id"/>
                <field name="active"/>
              </group>
            </group>
            <group string="Issue">
              <field name="name"/>
              <field name="recommended_action" nolabel="1"/>
            </group>
          </sheet>
        </form>
      </field>
    </record>

    <record id="view_southbrook_data_quality_issue_search" model="ir.ui.view">
      <field name="name">southbrook.project.data.quality.issue.search</field>
      <field name="model">southbrook.project.data.quality.issue</field>
      <field name="arch" type="xml">
        <search string="Data Quality Issues">
          <field name="name"/>
          <field name="issue_type"/>
          <field name="model_name"/>
          <filter name="active" string="Active" domain="[('active','=',True)]"/>
          <filter name="blockers"
                  string="Blockers"
                  domain="[('severity','=','blocker')]"/>
          <filter name="new"
                  string="New"
                  domain="[('state','=','new')]"/>
          <group>
            <filter name="group_issue_type"
                    string="Issue Type"
                    context="{'group_by':'issue_type'}"/>
            <filter name="group_severity"
                    string="Severity"
                    context="{'group_by':'severity'}"/>
            <filter name="group_state"
                    string="State"
                    context="{'group_by':'state'}"/>
          </group>
        </search>
      </field>
    </record>

    <record id="action_southbrook_data_quality_issues" model="ir.actions.act_window">
      <field name="name">Data Quality Dry Run</field>
      <field name="res_model">southbrook.project.data.quality.issue</field>
      <field name="view_mode">list,form</field>
      <field name="search_view_id" ref="view_southbrook_data_quality_issue_search"/>
      <field name="context">{'search_default_active': 1, 'search_default_new': 1}</field>
    </record>

    <record id="server_action_southbrook_data_quality_dry_run" model="ir.actions.server">
      <field name="name">Generate Southbrook Data Quality Dry Run</field>
      <field name="model_id" ref="model_southbrook_project_data_quality_issue"/>
      <field name="state">code</field>
      <field name="code">
issues = env['southbrook.project.data.quality.issue'].action_generate_dry_run_report()
action = {
    'type': 'ir.actions.act_window',
    'name': 'Data Quality Dry Run',
    'res_model': 'southbrook.project.data.quality.issue',
    'view_mode': 'list,form',
    'domain': [('id', 'in', issues.ids)],
}
      </field>
    </record>

    <menuitem id="menu_southbrook_generate_data_quality_issues"
              parent="southbrook_mrp_pm.menu_southbrook_pm_root"
              name="Generate Data Quality Dry Run"
              action="server_action_southbrook_data_quality_dry_run"
              groups="southbrook_project.group_southbrook_pm"
              sequence="94"/>
    <menuitem id="menu_southbrook_data_quality_issues"
              parent="southbrook_mrp_pm.menu_southbrook_pm_root"
              name="Data Quality Dry Run"
              action="action_southbrook_data_quality_issues"
              groups="southbrook_project.group_southbrook_pm,southbrook_project.group_southbrook_executive"
              sequence="95"/>
  </data>
</odoo>
