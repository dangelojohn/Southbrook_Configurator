<?xml version="1.0" encoding="utf-8"?>
<!--
  Six project.tags covering the most common Southbrook task tagging:
    Rush       — needs to ship ahead of normal SLA
    Custom     — non-stock cabinet sizing / hardware
    Warranty   — work covered under existing warranty (no charge)
    Repair     — service call, not new manufacture
    Kitchen    — kitchen scope (vs vanity / built-in)
    Vanity     — bathroom vanity scope
  Color codes are stock Odoo palette indices (1-11).
-->
<odoo>
    <data noupdate="1">

        <record id="tag_rush" model="project.tags">
            <field name="name">Rush</field>
            <field name="color">1</field>
        </record>

        <record id="tag_custom" model="project.tags">
            <field name="name">Custom</field>
            <field name="color">2</field>
        </record>

        <record id="tag_warranty" model="project.tags">
            <field name="name">Warranty</field>
            <field name="color">3</field>
        </record>

        <record id="tag_repair" model="project.tags">
            <field name="name">Repair</field>
            <field name="color">4</field>
        </record>

        <record id="tag_kitchen" model="project.tags">
            <field name="name">Kitchen</field>
            <field name="color">5</field>
        </record>

        <record id="tag_vanity" model="project.tags">
            <field name="name">Vanity</field>
            <field name="color">6</field>
        </record>

    </data>
</odoo>
