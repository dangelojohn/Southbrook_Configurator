<?xml version="1.0" encoding="utf-8"?>
<!--
  Shop Copy — MO-companion document, bound to mrp.production.

  Per Build Spec section 4 routine #6. The shop floor's work-order companion:
  panel cut list, hardware list, edge banding, originating SO reference.

  CRITICAL DATA BINDING (per John's commit-10 ask):
  The Shop Copy reads from mrp.production — NOT from sale.order. The
  legacy spreadsheet Shop Copy tab was 254 cell-level formulas mirroring
  the order form. The Odoo version generates from the MO's BoM rollup
  (which is what manufacturing actually consumes), eliminating the
  mirror duplication entirely.

  NF25 (caught at live test run 2026-05-30): Odoo 19 dropped the
  `mrp.production.sale_id` shortcut field. The canonical MO→SO link
  through `sale_mrp` is now `mo.sale_line_id.order_id` (M2O.M2O chain),
  with a fallback to the free-text `mo.origin` for MOs that don't have
  a sale_line_id (manually created MOs, demo fixtures, etc.). The
  template uses a t-set to resolve the SO once and references the
  resolved value below.

  Phase-1 minimum: MO header + cabinet dimensions + BoM line table
    + originating SO ref.
  Phase-2 polish: per-panel cut diagrams (when SVG tooling lands).
-->
<odoo>

  <template id="report_shop_copy_doc" name="Shop Copy Document">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="mo">
        <t t-call="web.external_layout">
          <t t-call="southbrook_estimating.southbrook_report_styles"/>
          <div class="page southbrook-report">

            <h1>Shop Copy</h1>
            <h2 t-out="mo.name"/>
            <hr class="sb-rule"/>

            <t t-set="so" t-value="mo.sale_line_id.order_id"/>
            <div>
              <strong>Originating Order:</strong>
              <span t-out="so.name or mo.origin or '—'"/>
              <span class="sb-muted" t-if="so and so.partner_id">
                / <span t-out="so.partner_id.name"/>
              </span><br/>
              <strong>Product:</strong>
              <span t-out="mo.product_id.display_name"/><br/>
              <strong>Quantity:</strong>
              <span t-out="mo.product_qty"/>
              <span t-out="mo.product_uom_id.name"/><br/>
              <strong>Effective Lead Time:</strong>
              <span t-out="mo.bom_id.effective_produce_delay if mo.bom_id else 0"/>
              <span class="sb-muted">days</span>
              <span class="sb-muted"
                    t-if="mo.bom_id and mo.bom_id.southbrook_lead_time_extra">
                (includes
                <span t-out="mo.bom_id.southbrook_lead_time_extra"/>
                day bump from selected attributes)
              </span>
            </div>

            <hr class="sb-rule"/>

            <h2>BoM — Cut List + Hardware</h2>
            <table>
              <thead>
                <tr>
                  <th>Component</th>
                  <th>Quantity</th>
                  <th>UoM</th>
                </tr>
              </thead>
              <tbody>
                <tr t-foreach="mo.bom_id.bom_line_ids" t-as="bl">
                  <td t-out="bl.product_id.display_name"/>
                  <td t-out="bl.product_qty"/>
                  <td t-out="bl.product_uom_id.name"/>
                </tr>
                <tr t-if="not mo.bom_id or not mo.bom_id.bom_line_ids">
                  <td colspan="3" class="sb-muted">
                    No BoM lines materialised. The parametric BoM rollup
                    fires at MO creation; if this row is empty, check the
                    cabinet's recipe wiring.
                  </td>
                </tr>
              </tbody>
            </table>

            <!-- Phase 4 Sprint 4 — panel cut list with dimensions.
                 Pulls from the sb.production.package.cutlist_id that
                 generate_from_mo() spawns at MO confirm. Falls back
                 gracefully when the package hasn't been built yet
                 (paranoid manual-MO and demo-fixture paths). -->
            <!-- env.get is safe — returns None when southbrook_kitchen_mrp
                 isn't installed. The Panel Cut List section then no-ops. -->
            <t t-set="PkgModel" t-value="env.get('sb.production.package')"/>
            <t t-set="pkg" t-value="PkgModel.sudo().search([('mo_id', '=', mo.id)], limit=1) if PkgModel is not None else False"/>
            <t t-if="pkg and pkg.cutlist_id">
              <h2>Panel Cut List (mm)</h2>
              <table>
                <thead>
                  <tr>
                    <th>Panel</th>
                    <th class="sb-right">Qty</th>
                    <th class="sb-right">L (mm)</th>
                    <th class="sb-right">W (mm)</th>
                    <th class="sb-right">Thk (mm)</th>
                    <th>Substrate</th>
                    <th>Grain</th>
                  </tr>
                </thead>
                <tbody>
                  <tr t-foreach="pkg.cutlist_id.line_ids" t-as="ln">
                    <td t-out="dict(ln._fields['panel_name'].selection).get(ln.panel_name, ln.panel_name)"/>
                    <td class="sb-right" t-out="ln.qty"/>
                    <td class="sb-right" t-out="'%.1f' % ln.length_mm"/>
                    <td class="sb-right" t-out="'%.1f' % ln.width_mm"/>
                    <td class="sb-right" t-out="'%.2f' % ln.thickness_mm"/>
                    <td t-out="dict(ln._fields['substrate'].selection).get(ln.substrate, '-') if ln.substrate else '-'"/>
                    <td t-out="dict(ln._fields['grain_dir'].selection).get(ln.grain_dir, '-') if ln.grain_dir else '-'"/>
                  </tr>
                </tbody>
              </table>
              <p class="sb-muted" t-if="pkg.hardware_package_id">
                Hardware package
                <strong t-out="pkg.hardware_package_id.name"/>
                covers <span t-out="len(pkg.hardware_package_id.line_ids)"/>
                SKU rows.
                <span t-if="pkg.hardware_package_id.has_pricing_pending">
                  Some SKUs have pending pricing.
                </span>
              </p>
            </t>

            <p class="sb-muted">
              Shop Copy data is MO-driven (mrp.production). All panel
              dimensions and hardware counts derive from
              _compute_panel_dimensions (custom routine #1, commit 8)
              applied to the variant's W x H x D + attribute values.
              No mirror duplication of the order form.
            </p>
          </div>
        </t>
      </t>
    </t>
  </template>

  <record id="action_report_shop_copy" model="ir.actions.report">
    <field name="name">Shop Copy</field>
    <field name="model">mrp.production</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">southbrook_estimating.report_shop_copy_doc</field>
    <field name="report_file">southbrook_estimating.report_shop_copy_doc</field>
    <field name="print_report_name">'Shop Copy - %s' % (object.name)</field>
    <field name="binding_model_id" ref="mrp.model_mrp_production"/>
    <field name="binding_type">report</field>
  </record>

</odoo>
