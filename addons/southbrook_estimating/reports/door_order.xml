<?xml version="1.0" encoding="utf-8"?>
<!--
  Door Order — per-order door schedule, bound to sale.order.

  Per Build Spec section 4 routine #6 + Mapping section 3.7. Replaces the
  workbook's manual Door Order tab. Aggregates the doors needed for ONE
  sale.order by series + colour + door style + size.

  Phase-1 simplification: per-SO scope. The original workbook tab
  aggregated doors across all open orders for batched supplier ordering.
  Multi-order aggregation lives in a sibling report (or a wizard) when
  Phase 2 introduces the door-supplier workflow.

  For Signature series doors (custom), each door line includes the door
  spec verbatim. For Contractor series (single white thermofoil), the
  report aggregates total square footage at the bottom — matching the
  format the door supplier already accepts.
-->
<odoo>

  <template id="report_door_order_doc" name="Door Order Document">
    <t t-call="web.html_container">
      <t t-foreach="docs" t-as="o">
        <t t-call="web.external_layout">
          <t t-call="southbrook_estimating.southbrook_report_styles"/>
          <div class="page southbrook-report">

            <h1>Door Order</h1>
            <h2>
              <span t-out="o.name"/>
              <span class="sb-muted">
                / <span t-out="o.partner_id.name"/>
              </span>
            </h2>
            <hr class="sb-rule"/>

            <table>
              <thead>
                <tr>
                  <th>Cabinet</th>
                  <th>Series</th>
                  <th>Door Style</th>
                  <th>Finish</th>
                  <th>Hinge</th>
                  <th class="sb-right">Doors</th>
                  <th class="sb-right">W (mm)</th>
                  <th class="sb-right">H (mm)</th>
                </tr>
              </thead>
              <tbody>
                <!-- Phase 4 Sprint 4 — door order rows now use the
                     B2 sb_width_mm + sb_door_count fields on the line
                     for accurate door specs even on demo orders without
                     a configurator session. Height comes from a small
                     family heuristic since the door height equals the
                     cabinet inside height minus reveals. -->
                <tr t-foreach="o.order_line" t-as="line">
                  <td t-out="line.product_id.display_name or line.name"/>
                  <td>
                    <t t-set="series_vals"
                       t-value="line.product_id.product_template_attribute_value_ids.filtered(
                          lambda v: v.attribute_id.name == 'Series')"/>
                    <span t-out="series_vals[:1].name or '—'"/>
                  </td>
                  <td>
                    <t t-set="ds"
                       t-value="line.product_id.product_template_attribute_value_ids.filtered(
                          lambda v: v.attribute_id.name == 'Door Style')"/>
                    <span t-out="ds[:1].name or '—'"/>
                  </td>
                  <td>
                    <t t-set="fn"
                       t-value="line.product_id.product_template_attribute_value_ids.filtered(
                          lambda v: v.attribute_id.name == 'Finish')"/>
                    <span t-out="fn[:1].name or '—'"/>
                  </td>
                  <td>
                    <t t-set="hs"
                       t-value="line.product_id.product_template_attribute_value_ids.filtered(
                          lambda v: v.attribute_id.name == 'Hinge Side')"/>
                    <span t-out="hs[:1].name or '—'"/>
                  </td>
                  <td class="sb-right" t-out="line.sb_door_count or 0"/>
                  <td class="sb-right">
                    <t t-if="line.sb_width_mm">
                      <span t-out="'%.0f' % line.sb_width_mm"/>
                    </t>
                    <t t-else=""><span class="sb-muted">—</span></t>
                  </td>
                  <td class="sb-right">
                    <!-- Heuristic family→height: base=720, wall=760,
                         tall=2100. The B2 derivation picks the matching
                         default; we re-derive here from line.name since
                         the height isn't a separate field on the line. -->
                    <t t-set="nm" t-value="(line.name or '').lower()"/>
                    <t t-if="'wall' in nm"><span>760</span></t>
                    <t t-elif="'tall' in nm or 'pantry' in nm"><span>2100</span></t>
                    <t t-elif="line.sb_width_mm"><span>720</span></t>
                    <t t-else=""><span class="sb-muted">—</span></t>
                  </td>
                </tr>
              </tbody>
            </table>

            <hr class="sb-rule"/>

            <!-- Phase 4 Sprint 4 — series totals footer for batched
                 supplier ordering. The supplier groups by series since
                 each series has its own door catalog + ordering form. -->
            <t t-set="series_totals" t-value="{}"/>
            <t t-foreach="o.order_line" t-as="ln">
              <t t-set="sv"
                 t-value="ln.product_id.product_template_attribute_value_ids.filtered(
                    lambda v: v.attribute_id.name == 'Series')[:1].name or 'Unknown'"/>
              <t t-set="cur" t-value="series_totals.get(sv, 0)"/>
              <t t-set="series_totals" t-value="dict(series_totals, **{sv: cur + (ln.sb_door_count or 0)})"/>
            </t>

            <h3>Doors by Series</h3>
            <table>
              <thead>
                <tr>
                  <th>Series</th>
                  <th class="sb-right">Total Doors</th>
                </tr>
              </thead>
              <tbody>
                <tr t-foreach="series_totals.items()" t-as="row">
                  <td t-out="row[0]"/>
                  <td class="sb-right" t-out="row[1]"/>
                </tr>
              </tbody>
            </table>

            <p class="sb-muted">
              Per-SO scope. Multi-order aggregation across all open
              SOs (batched supplier ordering) is a separate report.
            </p>
          </div>
        </t>
      </t>
    </t>
  </template>

  <record id="action_report_door_order" model="ir.actions.report">
    <field name="name">Door Order</field>
    <field name="model">sale.order</field>
    <field name="report_type">qweb-pdf</field>
    <field name="report_name">southbrook_estimating.report_door_order_doc</field>
    <field name="report_file">southbrook_estimating.report_door_order_doc</field>
    <field name="print_report_name">'Door Order - %s' % (object.name)</field>
    <field name="binding_model_id" ref="sale.model_sale_order"/>
    <field name="binding_type">report</field>
  </record>

</odoo>
