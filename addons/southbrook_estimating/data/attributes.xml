<?xml version="1.0" encoding="utf-8"?>
<!--
  The 11 user-facing attributes (Mapping §3.3 / Q2 locked list) + the 2 derived
  attributes from Q22(a) [door_count hidden] and Q23(b) [family_subtype scoped
  to corner template] + the 1 sub-attribute from Q8 [accessory_type].

  Per Q6: all create_variant='dynamic'. Per Q4: width values carry both
  value_inches (display) and value_mm (canonical, from #5 Price Master tab).
  Per Q3: maple box carries lead_time_extra=14 days (+2 weeks).
-->
<odoo noupdate="0">

  <!-- ============================================================== -->
  <!-- 1 · family                                                     -->
  <!-- ============================================================== -->
  <record id="attr_family" model="product.attribute">
    <field name="name">Family</field>
    <field name="display_type">select</field>
    <field name="create_variant">dynamic</field>
    <field name="sequence">1</field>
  </record>
  <record id="value_family_wall" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family"/>
    <field name="name">Wall</field><field name="sequence">1</field>
  </record>
  <record id="value_family_base" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family"/>
    <field name="name">Base</field><field name="sequence">2</field>
  </record>
  <record id="value_family_drawer" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family"/>
    <field name="name">Drawer Bank</field><field name="sequence">3</field>
  </record>
  <record id="value_family_sink" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family"/>
    <field name="name">Sink</field><field name="sequence">4</field>
  </record>
  <record id="value_family_tall" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family"/>
    <field name="name">Tall</field><field name="sequence">5</field>
  </record>
  <record id="value_family_corner" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family"/>
    <field name="name">Corner</field><field name="sequence">6</field>
  </record>
  <record id="value_family_vanity" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family"/>
    <field name="name">Vanity</field><field name="sequence">7</field>
  </record>
  <record id="value_family_worktop" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family"/>
    <field name="name">Worktop</field><field name="sequence">8</field>
  </record>
  <record id="value_family_accessory" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family"/>
    <field name="name">Accessory</field><field name="sequence">9</field>
  </record>

  <!-- Q23(b) — family_subtype scoped via attribute_line to corner only -->
  <record id="attr_family_subtype" model="product.attribute">
    <field name="name">Family Subtype</field>
    <field name="display_type">radio</field>
    <field name="create_variant">dynamic</field>
    <field name="sequence">2</field>
  </record>
  <record id="value_family_subtype_standard" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family_subtype"/>
    <field name="name">Standard</field><field name="sequence">1</field>
  </record>
  <record id="value_family_subtype_bifold" model="product.attribute.value">
    <field name="attribute_id" ref="attr_family_subtype"/>
    <field name="name">Bi-fold</field><field name="sequence">2</field>
  </record>

  <!-- ============================================================== -->
