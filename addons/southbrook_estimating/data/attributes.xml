  <!-- Canonical mm values from #5 Price Master tab. DO NOT compute    -->
  <!-- one from the other — spec rounds differently than literal       -->
  <!-- conversion (e.g. 9″ = 228mm not 228.6mm).                       -->
  <!-- ============================================================== -->
  <record id="attr_width" model="product.attribute">
    <field name="name">Width</field>
    <field name="display_type">select</field>
    <field name="create_variant">dynamic</field>
    <field name="sequence">10</field>
  </record>
  <record id="value_width_9" model="product.attribute.value">
    <field name="attribute_id" ref="attr_width"/>
    <field name="name">9 in</field>
    <field name="value_inches">9</field>
    <field name="value_mm">228</field>
    <field name="sequence">1</field>
  </record>
  <record id="value_width_12" model="product.attribute.value">
    <field name="attribute_id" ref="attr_width"/>
    <field name="name">12 in</field>
    <field name="value_inches">12</field>
    <field name="value_mm">304</field>
    <field name="sequence">2</field>
  </record>
  <record id="value_width_15" model="product.attribute.value">
    <field name="attribute_id" ref="attr_width"/>
    <field name="name">15 in</field>
    <field name="value_inches">15</field>
    <field name="value_mm">381</field>
    <field name="sequence">3</field>
  </record>
  <record id="value_width_18" model="product.attribute.value">
    <field name="attribute_id" ref="attr_width"/>
    <field name="name">18 in</field>
    <field name="value_inches">18</field>
    <field name="value_mm">457</field>
    <field name="sequence">4</field>
  </record>
  <record id="value_width_21" model="product.attribute.value">
    <field name="attribute_id" ref="attr_width"/>
    <field name="name">21 in</field>
    <field name="value_inches">21</field>
    <field name="value_mm">533</field>
    <field name="sequence">5</field>
  </record>
  <record id="value_width_24" model="product.attribute.value">
    <field name="attribute_id" ref="attr_width"/>
    <field name="name">24 in</field>
    <field name="value_inches">24</field>
    <field name="value_mm">609</field>
    <field name="sequence">6</field>
  </record>
  <record id="value_width_27" model="product.attribute.value">
    <field name="attribute_id" ref="attr_width"/>
    <field name="name">27 in</field>
    <field name="value_inches">27</field>
    <field name="value_mm">685</field>
    <field name="sequence">7</field>
  </record>
  <record id="value_width_30" model="product.attribute.value">
    <field name="attribute_id" ref="attr_width"/>
    <field name="name">30 in</field>
    <field name="value_inches">30</field>
    <field name="value_mm">762</field>
    <field name="sequence">8</field>
  </record>
  <record id="value_width_33" model="product.attribute.value">
    <field name="attribute_id" ref="attr_width"/>
    <field name="name">33 in</field>
    <field name="value_inches">33</field>
    <field name="value_mm">838</field>
    <field name="sequence">9</field>
  </record>
  <record id="value_width_36" model="product.attribute.value">
    <field name="attribute_id" ref="attr_width"/>
    <field name="name">36 in</field>
    <field name="value_inches">36</field>
    <field name="value_mm">914</field>
    <field name="sequence">10</field>
  </record>

  <!-- ============================================================== -->
  <!-- 3 · series (the most discriminating attribute)                 -->
  <!-- ============================================================== -->
  <record id="attr_series" model="product.attribute">
    <field name="name">Series</field>
    <field name="display_type">radio</field>
    <field name="create_variant">dynamic</field>
    <field name="sequence">20</field>
  </record>
  <record id="value_series_contractor" model="product.attribute.value">
    <field name="attribute_id" ref="attr_series"/>
    <field name="name">Contractor Series</field><field name="sequence">1</field>
  </record>
  <record id="value_series_contemporary" model="product.attribute.value">
    <field name="attribute_id" ref="attr_series"/>
    <field name="name">Contemporary</field><field name="sequence">2</field>
  </record>
  <record id="value_series_elegance" model="product.attribute.value">
    <field name="attribute_id" ref="attr_series"/>
    <field name="name">Elegance</field><field name="sequence">3</field>
  </record>
  <record id="value_series_signature" model="product.attribute.value">
    <field name="attribute_id" ref="attr_series"/>
    <field name="name">Signature</field><field name="sequence">4</field>
  </record>

  <!-- ============================================================== -->
  <!-- 4 · box_material — maple carries lead_time_extra=14 (Q3)       -->
  <!-- ============================================================== -->
  <record id="attr_box_material" model="product.attribute">
    <field name="name">Box Material</field>
    <field name="display_type">radio</field>
    <field name="create_variant">dynamic</field>
    <field name="sequence">30</field>
  </record>
  <record id="value_box_white_melamine" model="product.attribute.value">
    <field name="attribute_id" ref="attr_box_material"/>
    <field name="name">White Melamine</field><field name="sequence">1</field>
  </record>
  <record id="value_box_maple" model="product.attribute.value">
    <field name="attribute_id" ref="attr_box_material"/>
    <field name="name">Maple</field>
    <field name="lead_time_extra">14.0</field>
    <field name="sequence">2</field>
  </record>

  <!-- ============================================================== -->
  <!-- 5 · door_style                                                 -->
  <!-- ============================================================== -->
  <record id="attr_door_style" model="product.attribute">
    <field name="name">Door Style</field>
    <field name="display_type">select</field>
    <field name="create_variant">dynamic</field>
    <field name="sequence">40</field>
  </record>
  <record id="value_door_thermofoil_slab_white" model="product.attribute.value">
    <field name="attribute_id" ref="attr_door_style"/>
    <field name="name">Thermofoil Slab — White</field><field name="sequence">1</field>
  </record>
  <record id="value_door_five_piece_woodgrain" model="product.attribute.value">
    <field name="attribute_id" ref="attr_door_style"/>
    <field name="name">Five-Piece Woodgrain</field><field name="sequence">2</field>
  </record>
  <record id="value_door_custom" model="product.attribute.value">
    <field name="attribute_id" ref="attr_door_style"/>
    <field name="name">Custom (Signature)</field><field name="sequence">3</field>
