<?xml version="1.0" encoding="utf-8"?>
<!--
  Declarative configurator rules from Mapping section 3.4.
  All encoded as product.config.line records keyed by trigger domain.

  Q22(a) — door_count is a hidden 12th attribute; Rule 3 restricts it to
           {1} for narrow widths and {2} for wide widths.
  Q23(b) — family_subtype is scoped to the corner template; Rule 4 hides
           soft_close when family_subtype=bifold.

  Per-template multiplication:
    Rule 3: 20 records (10 templates with door_count x 2 width bands)
    Rule 4: 1 record (corner template, accessories restriction)

  Rule 1 (Series→Door Style) and Rule 2 (Box Material→Series) used to
  live in this file as per-series whitelist config.lines. They were
  removed on 2026-06-03 because the per-series structure didn't match
  OCA values_available semantics — picking Contemporary or Elegance
  disabled BOTH box materials for the customer. The replacement is a
  unified per-value rule generator in
    southbrook_configurator_ux/models/rule_completion.py
  which builds one config.line per (template × value) with a single
  per-value "Series allows V" domain. It covers the Q8 templates here
  plus the 40 catalog templates from
  southbrook_configurator_ux/models/catalog_expansion.py.

  Templates referenced here come from data/product_templates.xml.
  This file MUST load AFTER product_templates.xml in the manifest.

  Generation note: hand-authored XML chosen over Python emission script
  for grep-friendliness. `git log` with a Rule keyword filter lands here.
-->
<odoo noupdate="0">

  <!-- ============================================================== -->
  <!-- DOMAINS — the named triggers (Q5 series keys, Q22 width bands) -->
  <!-- ============================================================== -->

  <!--
    Rule 1 (Series→Door Style) + Rule 2 (Box Material→Series) used to
    seed the per-series "Series is Contractor" / "Series is Elegance" /
    "Series is Signature" domains here. Those rules + domains were
    REMOVED on 2026-06-03 because the per-series whitelist structure
    didn't match OCA values_available semantics — picking Contemporary
    or Elegance left customers with no available box material (both
    appeared in the Contractor/Signature rules whose domains didn't
    match, so the engine treated them as restricted-and-disabled).

    The replacement lives in
      southbrook_configurator_ux/models/rule_completion.py
    which generates one config.line per (template × value) with a
    single per-value "Series allows V" domain expressing the full
    OR-list of permitted series. It covers BOTH the Q8 templates
    here AND the 40 catalog templates created by
    southbrook_configurator_ux/models/catalog_expansion.py, which
    don't have stable xml_ids for static rules to reference.

    To restore static seeding for the Q8 set, copy the deltas table
    from rule_completion.py back into XML here. Catalog templates
    will always need the code-driven path.
  -->

  <!-- Rule 3 width-band triggers (Q22(a)) -->
  <record id="domain_width_narrow" model="product.config.domain">
    <field name="name">Width is Narrow (9-21 in)</field>
  </record>
  <record id="domain_width_narrow_line" model="product.config.domain.line">
    <field name="domain_id" ref="domain_width_narrow"/>
    <field name="attribute_id" ref="attr_width"/>
    <field name="condition">in</field>
    <field name="operator">and</field>
    <field name="value_ids" eval="[(6, 0, [
      ref('value_width_9'), ref('value_width_12'), ref('value_width_15'),
      ref('value_width_18'), ref('value_width_21')
    ])]"/>
  </record>

  <record id="domain_width_wide" model="product.config.domain">
    <field name="name">Width is Wide (24-36 in)</field>
  </record>
  <record id="domain_width_wide_line" model="product.config.domain.line">
    <field name="domain_id" ref="domain_width_wide"/>
    <field name="attribute_id" ref="attr_width"/>
    <field name="condition">in</field>
    <field name="operator">and</field>
    <field name="value_ids" eval="[(6, 0, [
      ref('value_width_24'), ref('value_width_27'), ref('value_width_30'),
      ref('value_width_33'), ref('value_width_36')
    ])]"/>
  </record>

  <!-- Rule 4 trigger (Q23(b)) -->
  <record id="domain_family_subtype_bifold" model="product.config.domain">
    <field name="name">Family Subtype is Bi-fold</field>
  </record>
  <record id="domain_family_subtype_bifold_line" model="product.config.domain.line">
    <field name="domain_id" ref="domain_family_subtype_bifold"/>
    <field name="attribute_id" ref="attr_family_subtype"/>
    <field name="condition">in</field>
    <field name="operator">and</field>
    <field name="value_ids" eval="[(6, 0, [ref('value_family_subtype_bifold')])]"/>
  </record>



  <!-- ============================================================== -->
  <!-- RULE 3 — Width → Door Count (Q22(a))                           -->
  <!-- Narrow (9-21 in) → door_count=1                                -->
  <!-- Wide (24-36 in)  → door_count=2                                -->
  <!-- ============================================================== -->
<record id="rule3_width_narrow_door_count_wall_1dr" model="product.config.line">
  <field name="product_tmpl_id" ref="wall_1dr"/>
  <field name="attribute_line_id" ref="attr_line_wall_1dr_door_count"/>
  <field name="value_ids" eval="[(6, 0, [ref('value_door_count_1')])]"/>
  <field name="domain_id" ref="domain_width_narrow"/>
  <field name="sequence">20000</field>
</record>

