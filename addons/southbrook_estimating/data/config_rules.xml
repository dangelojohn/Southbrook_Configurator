  <!-- ============================================================== -->
  <!-- RULE 4 — Family Subtype → Soft-Close (Q23(b))                  -->
  <!-- When family_subtype=bifold on corner: restrict accessories     -->
  <!-- to {drawer_organisers, pull_outs} — omits soft_close (hides). -->
  <!-- ============================================================== -->
<record id="rule4_family_subtype_bifold_accessories_corner" model="product.config.line">
  <field name="product_tmpl_id" ref="corner"/>
  <field name="attribute_line_id" ref="attr_line_corner_accessories"/>
