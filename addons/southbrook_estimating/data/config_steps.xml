<?xml version="1.0" encoding="utf-8"?>
<!--
  Phase 2K (audit 2026-06-09) — wizard step grouping.

  Without product.config.step records, the OCA wizard renders
  all 18-21 attribute_lines per cabinet as one long flat scroll.
  At Southbrook's post-audit attribute count, that is unusable.

  Four step buckets cover every audit attribute:

    1. Construction &amp; Sizing — family / width / series / box /
       frame_style / door_count / family_subtype
    2. Door &amp; Finish        — door_style / overlay / species /
       finish / edge / glass / crown
    3. Hardware &amp; Sides     — hinge / handle / pull_finish /
       finished_sides / gables
    4. Interior &amp; Accessories — drawer_construction / interior_storage /
       lighting / accessories

  Per-cabinet step_lines reference only the attribute_lines that
  actually exist on each template (e.g. sink_base has no
  drawer_construction, so its Interior step omits that ref).
-->
<odoo noupdate="0">

  <!-- ============================================================== -->
  <!-- Four step buckets (global, shared across all 10 cabinets)       -->
  <!-- ============================================================== -->
  <record id="step_construction" model="product.config.step">
    <field name="name">Construction &amp; Sizing</field>
  </record>
  <record id="step_door_finish" model="product.config.step">
    <field name="name">Door &amp; Finish</field>
  </record>
  <record id="step_hardware" model="product.config.step">
    <field name="name">Hardware &amp; Sides</field>
  </record>
  <record id="step_interior" model="product.config.step">
    <field name="name">Interior &amp; Accessories</field>
  </record>

