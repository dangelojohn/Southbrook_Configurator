<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!--
        Default to the mock backend so installs/tests pass without an
        API key. Flip to False in production via Settings → Technical →
        System Parameters or via env-driven post-install hook.
    -->
    <record id="param_gemini_use_mock" model="ir.config_parameter">
        <field name="key">gemini.use_mock</field>
        <field name="value">True</field>
    </record>
    <record id="param_gemini_api_key" model="ir.config_parameter">
        <field name="key">gemini.api_key</field>
        <field name="value"></field>
    </record>
</odoo>
