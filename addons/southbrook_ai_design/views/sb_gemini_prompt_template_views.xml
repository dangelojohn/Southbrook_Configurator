<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sb_gemini_prompt_template_list" model="ir.ui.view">
        <field name="name">sb.gemini.prompt.template.list</field>
        <field name="model">sb.gemini.prompt.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="model"/>
                <field name="active" widget="boolean_toggle"/>
                <field name="version_note"/>
            </list>
        </field>
    </record>

    <record id="view_sb_gemini_prompt_template_form" model="ir.ui.view">
        <field name="name">sb.gemini.prompt.template.form</field>
        <field name="model">sb.gemini.prompt.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="active"/>
                            <field name="model"/>
                            <field name="version_note"/>
                        </group>
                        <group>
                            <field name="temperature"/>
                            <field name="top_k"/>
                            <field name="top_p"/>
                            <field name="max_output_tokens"/>
                        </group>
                    </group>
                    <field name="body" widget="text"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sb_gemini_prompt_template" model="ir.actions.act_window">
        <field name="name">Gemini Prompt Templates</field>
        <field name="res_model">sb.gemini.prompt.template</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
